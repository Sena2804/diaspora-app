# =============================================================================
# DiasporaConnect — Variables d'environnement
# =============================================================================
# COPIE ce fichier en .env.local puis remplis les vraies valeurs.
# Le .env.local est ignoré par Git (voir .gitignore) — ne jamais committer.
# Les variables préfixées par NEXT_PUBLIC_ sont exposées au navigateur.
# Les autres ne vivent QUE côté serveur (Route Handlers).
# =============================================================================

# --- Supabase ----------------------------------------------------------------
# À récupérer dans Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx...
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxx...   # ⚠️ Server-only, ne jamais exposer

# --- Stellar testnet ---------------------------------------------------------
# Wallet plateforme créé le 10 mai via Stellar Laboratory
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015
STELLAR_PLATFORM_PUBLIC=GC565GXNDAFF23GVITSGPWPYQ3PXQC4LFDDYG6HLQWFFAXOQYU5PKTJQ
STELLAR_PLATFORM_SECRET=Sxxxxx...       # ⚠️ Server-only, ta clé secrète Stellar
STELLAR_USDC_ASSET_CODE=USDC
STELLAR_USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# --- Provider de payout (Kkiapay en J1) --------------------------------------
PAYOUT_PROVIDER=kkiapay                 # kkiapay | cinetpay | fedapay | mock

# --- Kkiapay (sandbox) -------------------------------------------------------
# À récupérer dans dashboard Kkiapay → Développeurs → API
NEXT_PUBLIC_KKIAPAY_PUBLIC=xxxxxxxxxxxxxxxxx
KKIAPAY_PRIVATE=tpk_xxxxx...            # ⚠️ Server-only
KKIAPAY_SECRET=tsk_xxxxx...             # ⚠️ Server-only, pour vérifier les webhooks
KKIAPAY_SANDBOX=true
KKIAPAY_BASE_URL=https://api-sandbox.kkiapay.me

# --- App ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_DEMO_MODE=false             # true en J6 pour simuler Cinetpay/Kkiapay si tombe
